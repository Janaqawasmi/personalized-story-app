// firestore.rules
//
// PHASE 1: Firestore Security Rules
//
// These rules provide a SECOND layer of protection at the database level.
// Even if the Express middleware is bypassed (e.g., direct Firestore SDK access),
// these rules enforce governance constraints.
//
// IMPORTANT: These rules assume Firebase Auth is used for authentication.
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ────────────────────────────────────────────────────
    // Helper functions
    // ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isSpecialistOrAdmin() {
      return hasRole('specialist') || hasRole('admin');
    }

    // ────────────────────────────────────────────────────
    // Story Briefs
    // ────────────────────────────────────────────────────

    match /storyBriefs/{briefId} {
      // Any authenticated user can read
      allow read: if isAuthenticated();

      // Only specialists and admins can create
      // createdBy must match the authenticated user's UID
      allow create: if isSpecialistOrAdmin()
                    && request.resource.data.createdBy == request.auth.uid;

      // Only specialists and admins can update (for overrides)
      allow update: if isSpecialistOrAdmin();

      // Never allow delete — briefs are part of the audit trail
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────
    // Generation Contracts
    // ────────────────────────────────────────────────────

    match /generationContracts/{contractId} {
      // Any authenticated user can read
      allow read: if isAuthenticated();

      // Only the server (admin SDK) should write contracts.
      // Client-side writes are blocked entirely.
      // The Express backend uses the Admin SDK which bypasses these rules.
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Audit Trail — IMMUTABLE
    // ────────────────────────────────────────────────────

    match /auditTrail/{entryId} {
      // Any authenticated user can read audit entries
      allow read: if isAuthenticated();

      // Only the server (admin SDK) can write.
      // No client-side creates, updates, or deletes.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────
    // Clinical Rules (read-only for all)
    // ────────────────────────────────────────────────────

    match /clinicalRulesVersions/{versionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only

      match /{subcollection}/{docId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // ────────────────────────────────────────────────────
    // Reference Data (read-only for all)
    // ────────────────────────────────────────────────────

    match /referenceData/{docId} {
      allow read: if true; // Public reference data
      allow write: if false;
      
      // Allow access to subcollections (topics/items, situations/items)
      match /{subcollection}/{itemId} {
        allow read: if true; // Public reference data subcollections
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Story Drafts
    // ────────────────────────────────────────────────────

    match /storyDrafts/{draftId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only (generated by backend)
    }

    // ────────────────────────────────────────────────────
    // Story Templates (Public Stories)
    // ────────────────────────────────────────────────────

    match /story_templates/{templateId} {
      // Public read access for approved stories
      allow read: if true;
      // Only server can write
      allow write: if false; // Admin SDK only
    }

    // ────────────────────────────────────────────────────
    // Default: deny everything else
    // ────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
