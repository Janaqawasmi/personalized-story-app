rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────
    // Helper functions
    // ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isCaregiver() {
      return isAuthenticated() && request.auth.token.role == "caregiver";
    }

    function isSpecialist() {
      return isAuthenticated() && request.auth.token.role == "specialist";
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == "admin";
    }

    function isSpecialistOrAdmin() {
      return isSpecialist() || isAdmin();
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ────────────────────────────────────────────────────
    // Story Templates — public library (approved + active)
    // ────────────────────────────────────────────────────

    match /story_templates/{templateId} {
      // Public templates:
      // - The app's client queries and server approval flow use `status: "approved"`.
      // - Your server sets `isActive: true` when creating approved templates, but may not set `isPublished`.
      // Regular users (and even unauthenticated users, depending on your product choice) should be able to read approved + active templates.
      //
      // Admin/specialists can read all templates, including non-public drafts.
      allow read: if (
        (resource.data.status == "approved" && resource.data.isActive == true)
        || (resource.data.isPublished == true && resource.data.isActive == true)
        || isSpecialistOrAdmin()
      );
      // Admin dashboard (client) can update review workflow; otherwise server SDK
      allow create, delete: if false;
      allow update: if isSpecialistOrAdmin();
    }

    // ────────────────────────────────────────────────────
    // Caregivers
    // ────────────────────────────────────────────────────

    match /caregivers/{uid} {
      allow read: if (isOwner(uid) && isCaregiver()) || isAdmin();
      allow write: if isOwner(uid) && isCaregiver();

      // Favorites subcollection
      // Path: caregivers/{uid}/favorites/{storyId}
      // Owner-only read/write (does NOT require role claim)
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Cart subcollection
      match /cart/{cartItemId} {
        allow read: if isOwner(uid) && isCaregiver();
        allow write: if isOwner(uid) && isCaregiver();
      }

      // Purchases subcollection — read only (backend writes via Admin SDK)
      match /purchases/{purchaseId} {
        allow read: if isOwner(uid) && isCaregiver();
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Story Previews — read only by owning caregiver
    // ────────────────────────────────────────────────────

    match /storyPreviews/{previewId} {
      allow read: if isAuthenticated()
                  && (resource.data.caregiverUid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Personalized Stories — read only by owning caregiver
    // with isAccessible check
    // ────────────────────────────────────────────────────

    match /personalizedStories/{storyId} {
      allow read: if isAuthenticated()
                  && resource.data.caregiverUid == request.auth.uid
                  && resource.data.isAccessible == true;
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Specialist collections — specialist/admin only
    // ────────────────────────────────────────────────────

    match /storyBriefs/{briefId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;
    }

    match /generationContracts/{contractId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;

      match /history/{historyId} {
        allow read: if isSpecialistOrAdmin();
        allow write: if false;
      }
    }

    match /storyDrafts/{draftId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Audit Trail — admin read only, no client writes
    // ────────────────────────────────────────────────────

    match /auditTrail/{entryId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────
    // Clinical Rules (read-only for authenticated)
    // ────────────────────────────────────────────────────

    match /clinicalRulesVersions/{versionId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;

      match /{subcollection}/{docId} {
        allow read: if isSpecialistOrAdmin();
        allow write: if false;
      }
    }

    match /settings/{docId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Reference Data (public read)
    // ────────────────────────────────────────────────────

    match /referenceData/{docId} {
      allow read: if true;
      allow write: if false;

      match /{subcollection}/{itemId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Admin dashboard support collections (optional data)
    // ────────────────────────────────────────────────────

    match /psychologists/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_alerts/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_activity_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Default: deny everything else
    // ────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
