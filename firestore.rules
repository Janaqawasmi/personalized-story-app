rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────────
    // Helper functions
    // ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isCaregiver() {
      return isAuthenticated() && request.auth.token.role == "caregiver";
    }

    function isSpecialist() {
      return isAuthenticated() && request.auth.token.role == "specialist";
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == "admin";
    }

    function isSpecialistOrAdmin() {
      return isSpecialist() || isAdmin();
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ────────────────────────────────────────────────────
    // Story Templates — public library (approved + active)
    // ────────────────────────────────────────────────────

    match /story_templates/{templateId} {
      // Public templates:
      // - The app's client queries and server approval flow use `status: "approved"`.
      // - Your server sets `isActive: true` when creating approved templates, but may not set `isPublished`.
      // Regular users (and even unauthenticated users, depending on your product choice) should be able to read approved + active templates.
      //
      // Admin/specialists can read all templates, including non-public drafts.
      allow read: if (
        (resource.data.status == "approved" && resource.data.isActive == true)
        || (resource.data.isPublished == true && resource.data.isActive == true)
        || isSpecialistOrAdmin()
      );
      // Admin dashboard (client) can update review workflow; otherwise server SDK
      allow create, delete: if false;
      allow update: if isSpecialistOrAdmin();

      // Text variant review docs — admin or the specialist who owns this template only.
      // "Owner" is determined by story_templates/{templateId}.specialistId.
      // Caregivers and unrelated specialists are explicitly denied.
      // The server API (Admin SDK) manages all writes; the specialist client reads
      // through the REST endpoint, not directly — so direct client reads are an
      // emergency fallback only.
      match /textVariants/{pageNumber} {
        allow read: if isAdmin()
          || (isSpecialist()
              && get(/databases/$(database)/documents/story_templates/$(templateId)).data.specialistId == request.auth.uid);
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Caregivers
    // ────────────────────────────────────────────────────

    match /caregivers/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());

      function previewQuotaKeys() {
        return [
          "freePreviewUsed",
          "freePreviewUsedAt",
          "freePreviewId",
          "freePreviewPreviewId",
          "freePreviewStatus",
          "unlimitedPreviews"
        ];
      }

      function caregiverServerOnlyKeys() {
        return [
          "elevenLabsVoiceId",
          "elevenLabsVoiceStatus"
        ];
      }

      allow create: if isAuthenticated()
        && request.auth.uid == uid
        && isCaregiver()
        && !request.resource.data.keys().hasAny(previewQuotaKeys());

      allow update: if isAuthenticated()
        && request.auth.uid == uid
        && isCaregiver()
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(previewQuotaKeys())
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(caregiverServerOnlyKeys());

      allow delete: if false;

      // Favorites subcollection
      // Path: caregivers/{uid}/favorites/{storyId}
      // Owner-only read/write (does NOT require role claim)
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Cart subcollection
      match /cart/{cartItemId} {
        allow read: if isOwner(uid) && isCaregiver();
        allow write: if isOwner(uid) && isCaregiver();
      }

      // Purchases subcollection — read only (backend writes via Admin SDK)
      match /purchases/{purchaseId} {
        allow read: if isOwner(uid) && isCaregiver();
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Story Previews — read only by owning caregiver
    // ────────────────────────────────────────────────────

    match /storyPreviews/{previewId} {
      allow read: if isAuthenticated()
                  && (resource.data.caregiverUid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Personalized Stories — read only by owning caregiver
    // with isAccessible check
    // ────────────────────────────────────────────────────

    match /personalizedStories/{storyId} {
      allow read: if isAuthenticated()
                  && resource.data.caregiverUid == request.auth.uid
                  && resource.data.isAccessible == true;
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Specialist collections — specialist/admin only
    // ────────────────────────────────────────────────────

    match /storyBriefs/{briefId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;
    }

    // Spec v1.2 Story Brief form aggregate — server (Admin SDK) writes only
    match /dammaStoryBriefs/{briefId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;

      match /feedback/{feedbackId} {
        allow read: if isSpecialistOrAdmin();
        allow write: if false;
      }
    }

    match /storyDrafts/{draftId} {
      allow read: if isSpecialistOrAdmin();
      allow write: if false;
    }

    // ────────────────────────────────────────────────────
    // Audit Trail — admin read only, no client writes
    // ────────────────────────────────────────────────────

    match /auditTrail/{entryId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────
    // Reference Data (public read)
    // ────────────────────────────────────────────────────

    match /referenceData/{docId} {
      allow read: if true;
      allow write: if false;

      match /{subcollection}/{itemId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Admin dashboard support collections (optional data)
    // ────────────────────────────────────────────────────

    match /psychologists/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_alerts/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_activity_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /storyIdeas/{ideaId} {
      // Clients cannot write directly — all writes go through the Express backend using the Admin SDK, which bypasses rules
      allow create, update, delete: if false;

      // Read access: the submitter can read their own ideas, and admins can read all ideas
      allow read: if request.auth != null && (
        resource.data.submittedByUid == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
    }

    // ────────────────────────────────────────────────────
    // Specialist stories + v2 illustration artefacts (client read-only subcollections)
    // ────────────────────────────────────────────────────

    match /stories/{storyId} {
      allow read: if isSpecialistOrAdmin()
        && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow write: if false;

      match /visualBibles/{vbId} {
        allow read: if isSpecialistOrAdmin()
          && (isAdmin() || get(/databases/$(database)/documents/stories/$(storyId)).data.ownerUid == request.auth.uid);
        allow write: if false;
      }

      match /scenePlans/{spId} {
        allow read: if isSpecialistOrAdmin()
          && (isAdmin() || get(/databases/$(database)/documents/stories/$(storyId)).data.ownerUid == request.auth.uid);
        allow write: if false;
      }

      match /finalPrompts/{fpId} {
        allow read: if isSpecialistOrAdmin()
          && (isAdmin() || get(/databases/$(database)/documents/stories/$(storyId)).data.ownerUid == request.auth.uid);
        allow write: if false;
      }

      match /images/{imageId} {
        allow read: if isSpecialistOrAdmin()
          && (isAdmin() || get(/databases/$(database)/documents/stories/$(storyId)).data.ownerUid == request.auth.uid);
        allow write: if false;
      }

      match /illustrationJobs/{jobId} {
        allow read: if isSpecialistOrAdmin()
          && (isAdmin() || get(/databases/$(database)/documents/stories/$(storyId)).data.ownerUid == request.auth.uid);
        allow write: if false;
      }
    }

    // ────────────────────────────────────────────────────
    // Default: deny everything else
    // ────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
