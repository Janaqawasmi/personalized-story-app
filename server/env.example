# server/env.example
#
# Copy this file to server/.env and fill in real values.
# Never commit server/.env — it is gitignored because it holds live secrets.

# ── Server ──────────────────────────────────────────────────────────────────

PORT=5001

# ── Firebase ─────────────────────────────────────────────────────────────────
# Either point to a service-account JSON file…
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/serviceAccountKey.json
# …or embed the JSON inline (useful in CI / Render secrets):
# FIREBASE_SERVICE_ACCOUNT_JSON_INLINE={"type":"service_account",...}

# ── Anthropic (Agent 1 + text variant generation) ────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...

# Model used by Agent 1, Step 1 (Story Architect) and Step 2 (Author).
# Default in code: claude-opus-4-8 — override for cost-saving in dev.
# AGENT1_MODEL=claude-sonnet-4-6

# Model used for text-variant generation (Phase 3 — gendered {{CHILD_NAME}} rewrite).
# Default: claude-haiku-4-5-20251001 (fast, cost-efficient, adequate for
# structured JSON rewrite tasks with strict output contract).
# Set to a stronger model for higher-quality Hebrew/Arabic morphological output:
# TEXT_VARIANT_MODEL=claude-sonnet-4-6
TEXT_VARIANT_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (optional fallback / embeddings) ──────────────────────────────────

OPENAI_API_KEY=sk-proj-...

# ── Image generation (Seedream via ARK) ──────────────────────────────────────

ARK_API_KEY=...
ARK_API_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL_ID=seedream-4-0-250828
